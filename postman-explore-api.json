{
  "info": {
    "name": "Xoto OTT — Explore + Like API",
    "_postman_id": "xoto-explore-like-api-2024",
    "description": "Complete Postman collection for Explore API (likeCount, isLikedByUser, shareUrl, first episode preview) and Like Toggle API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "Auto-filled after running Verify OTP request"
    },
    {
      "key": "contentId",
      "value": "6a32c3497f027c383ceb9fc4",
      "type": "string",
      "description": "Drama content ID for like testing (CEO Billionaire)"
    }
  ],
  "item": [
    {
      "name": "🔐 Step 1 — Auth (Get Token)",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/app/auth/send-otp",
              "host": ["{{baseUrl}}"],
              "path": ["app", "auth", "send-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9999999999\"\n}"
            },
            "description": "Step 1: Send OTP to mobile number"
          }
        },
        {
          "name": "Verify OTP → Auto Save Token ✅",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  console.log('✅ Token saved successfully!');",
                  "  console.log('Token:', res.accessToken);",
                  "} else {",
                  "  console.log('❌ No token received:', JSON.stringify(res));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/app/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["app", "auth", "verify-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9999999999\",\n  \"otp\": \"1234\"\n}"
            },
            "description": "Step 2: Verify OTP with static code 1234. Token is auto-saved to {{accessToken}} variable."
          }
        }
      ]
    },
    {
      "name": "🎬 Step 2 — Explore API",
      "item": [
        {
          "name": "GET Explore — Dramas (No Auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.items.length > 0) {",
                  "  const firstId = res.data.items[0].id;",
                  "  pm.collectionVariables.set('contentId', firstId);",
                  "  console.log('✅ contentId saved:', firstId);",
                  "  console.log('Title:', res.data.items[0].title);",
                  "  console.log('likeCount:', res.data.items[0].likeCount);",
                  "  console.log('isLikedByUser:', res.data.items[0].isLikedByUser);",
                  "  console.log('shareUrl:', res.data.items[0].shareUrl);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/explore?contentType=drama&sort=new&offset=0&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["explore"],
              "query": [
                { "key": "contentType", "value": "drama", "description": "drama | movie" },
                { "key": "sort", "value": "new", "description": "new | trending | views | featured" },
                { "key": "offset", "value": "0" },
                { "key": "limit", "value": "5" }
              ]
            },
            "description": "Fetch drama reel feed WITHOUT auth.\n\nExpected in each item:\n✅ likeCount (number)\n✅ isLikedByUser: false (no auth)\n✅ shareUrl (deep link)\n✅ videoUrl (episode 1 only)\n✅ firstEpisodeId, firstEpisodeTitle, firstEpisodeDuration\n\n⚡ Test script auto-saves first contentId to {{contentId}} variable."
          }
        },
        {
          "name": "GET Explore — Dramas (With Auth ✅)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/explore?contentType=drama&sort=new&offset=0&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["explore"],
              "query": [
                { "key": "contentType", "value": "drama" },
                { "key": "sort", "value": "new" },
                { "key": "offset", "value": "0" },
                { "key": "limit", "value": "5" }
              ]
            },
            "description": "Fetch drama reel feed WITH auth token.\n✅ isLikedByUser will be true/false based on actual user likes"
          }
        },
        {
          "name": "GET Explore — Movies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/explore?contentType=movie&sort=trending&offset=0&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["explore"],
              "query": [
                { "key": "contentType", "value": "movie" },
                { "key": "sort", "value": "trending" },
                { "key": "offset", "value": "0" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "GET Explore — Sort: Trending",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/explore?contentType=drama&sort=trending&offset=0&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["explore"],
              "query": [
                { "key": "contentType", "value": "drama" },
                { "key": "sort", "value": "trending" },
                { "key": "offset", "value": "0" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "GET Explore — Sort: Most Viewed",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/explore?contentType=drama&sort=views&offset=0&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["explore"],
              "query": [
                { "key": "contentType", "value": "drama" },
                { "key": "sort", "value": "views" },
                { "key": "offset", "value": "0" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "GET Explore — Sort: Featured",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/explore?contentType=drama&sort=featured&offset=0&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["explore"],
              "query": [
                { "key": "contentType", "value": "drama" },
                { "key": "sort", "value": "featured" },
                { "key": "offset", "value": "0" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "GET Explore — Page 2 (Infinite Scroll)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/explore?contentType=drama&sort=new&offset=5&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["explore"],
              "query": [
                { "key": "contentType", "value": "drama" },
                { "key": "sort", "value": "new" },
                { "key": "offset", "value": "5", "description": "Use nextOffset from previous response" },
                { "key": "limit", "value": "5" }
              ]
            },
            "description": "Infinite scroll — page 2. Use 'nextOffset' value from previous response as offset."
          }
        }
      ]
    },
    {
      "name": "❤️ Step 3 — Like API",
      "item": [
        {
          "name": "LIKE — Drama (Toggle ❤️ → 🤍)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "console.log('Message:', res.message);",
                  "console.log('likeCount:', res.data?.likeCount);",
                  "console.log('isLikedByUser:', res.data?.isLikedByUser);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/like/{{contentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["like", "{{contentId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentType\": \"drama\"\n}"
            },
            "description": "Like or Unlike a drama.\n\n🔁 Call 1 → Liked  (isLikedByUser: true)\n🔁 Call 2 → Unliked (isLikedByUser: false)\n\nRequires: Bearer token from Verify OTP step.\ncontentId is auto-set from Explore API test script."
          }
        },
        {
          "name": "LIKE — Movie (Toggle ❤️ → 🤍)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/like/{{contentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["like", "{{contentId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentType\": \"movie\"\n}"
            },
            "description": "Like or Unlike a movie."
          }
        },
        {
          "name": "LIKE — No Auth (Should return 401 ❌)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/like/{{contentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["like", "{{contentId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentType\": \"drama\"\n}"
            },
            "description": "Should return 401 — Authentication required."
          }
        },
        {
          "name": "LIKE — Invalid Content ID (Should return 400 ❌)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/like/invalid-id-123",
              "host": ["{{baseUrl}}"],
              "path": ["like", "invalid-id-123"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentType\": \"drama\"\n}"
            },
            "description": "Should return 400 — Invalid contentId."
          }
        }
      ]
    }
  ]
}
