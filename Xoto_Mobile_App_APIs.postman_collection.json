{
  "info": {
    "_postman_id": "c1f7a8b9-1234-4a5b-9876-abcdef123456",
    "name": "Xoto Mobile App APIs",
    "description": "Complete collection for all Mobile App APIs (Auth, Home, Explore, Watch, Like, Settings)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "Auto-filled by OTP verify API"
    },
    {
      "key": "testDramaId",
      "value": "6a32d53705d1b8c731e8e201",
      "type": "string"
    },
    {
      "key": "testMovieId",
      "value": "6a32d53705d1b8c731e8e195",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phone\": \"+919876543210\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/app/auth/send-otp",
              "host": ["{{baseUrl}}"],
              "path": ["app", "auth", "send-otp"]
            }
          }
        },
        {
          "name": "Verify OTP (Auto-saves Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phone\": \"+919876543210\",\n    \"otp\": \"1234\",\n    \"fcmToken\": \"test-token\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/app/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["app", "auth", "verify-otp"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Main Pages",
      "item": [
        {
          "name": "Home Page (Dramas)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/home?tab=drama",
              "host": ["{{baseUrl}}"],
              "path": ["home"],
              "query": [
                { "key": "tab", "value": "drama" }
              ]
            }
          }
        },
        {
          "name": "Home Page (Movies)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/home?tab=movie",
              "host": ["{{baseUrl}}"],
              "path": ["home"],
              "query": [
                { "key": "tab", "value": "movie" }
              ]
            }
          }
        },
        {
          "name": "Explore (Infinite Scroll Feed)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/explore?contentType=drama&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["explore"],
              "query": [
                { "key": "contentType", "value": "drama" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Watch & Like",
      "item": [
        {
          "name": "Watch Details (Drama/Series)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/watch/{{testDramaId}}?season=1&episode=1",
              "host": ["{{baseUrl}}"],
              "path": ["watch", "{{testDramaId}}"],
              "query": [
                { "key": "season", "value": "1" },
                { "key": "episode", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Watch Details (Movie)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/watch/{{testMovieId}}",
              "host": ["{{baseUrl}}"],
              "path": ["watch", "{{testMovieId}}"]
            }
          }
        },
        {
          "name": "Like / Unlike Content",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/like/{{testDramaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["like", "{{testDramaId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Settings & Profile",
      "item": [
        {
          "name": "Get Profile Data",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/app/profile",
              "host": ["{{baseUrl}}"],
              "path": ["app", "profile"]
            }
          }
        },
        {
          "name": "Update Video Quality",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"videoQuality\": \"best\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/app/profile/video-quality",
              "host": ["{{baseUrl}}"],
              "path": ["app", "profile", "video-quality"]
            }
          }
        }
      ]
    }
  ]
}
