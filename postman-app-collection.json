{
  "info": {
    "name": "Triple Minds App API",
    "description": "Complete, production-ready Postman collection for testing the Triple Minds app API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9999999999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/app/auth/send-otp",
              "host": ["{{baseUrl}}"],
              "path": ["app", "auth", "send-otp"]
            },
            "description": "Sends a static OTP (1234) to any 10-digit mobile number"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\"success\": true}"
            }
          ]
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9999999999\",\n  \"otp\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/app/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["app", "auth", "verify-otp"]
            },
            "description": "Verifies OTP and returns JWT token"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\"success\": true, \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\", \"userId\": \"60c72b2f9b1d8e001f8e4b5a\", \"expiresIn\": 900}"
            }
          ]
        }
      ]
    },
    {
      "name": "Languages",
      "item": [
        {
          "name": "List Languages (with skip option)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/languages?includeSkip=true",
              "host": ["{{baseUrl}}"],
              "path": ["languages"],
              "query": [{"key": "includeSkip", "value": "true"}]
            },
            "description": "Gets list of active languages including a 'Skip' option"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\"success\": true, \"data\": [{\"id\": \"skip\", \"name\": \"Skip\", \"code\": \"skip\", \"image\": null, \"isActive\": true, \"order\": -1, \"createdAt\": null, \"updatedAt\": null, \"isSkippable\": true}, {\"id\": \"60c72b2f9b1d8e001f8e4b5a\", \"name\": \"Hindi\", \"code\": \"hi\", \"image\": \"/uploads/languages/hindi.png\", \"isActive\": true, \"order\": 1, \"createdAt\": \"2023-06-15T10:30:00.000Z\", \"updatedAt\": \"2023-06-15T10:30:00.000Z\"}]}"
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Set Preferred Language",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"Hindi\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/app/users/{{userId}}/language",
              "host": ["{{baseUrl}}"],
              "path": ["app", "users", "{{userId}}", "language"],
              "variable": [{"key": "userId", "value": ""}]
            },
            "description": "Sets user's preferred language"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\"success\": true, \"message\": \"Preferred language updated successfully\", \"data\": {\"userId\": \"60c72b2f9b1d8e001f8e4b5a\", \"preferredLanguage\": \"Hindi\", \"languageSelectionSkipped\": false}}"
            }
          ]
        },
        {
          "name": "Skip Language Selection",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/app/users/{{userId}}/language/skip",
              "host": ["{{baseUrl}}"],
              "path": ["app", "users", "{{userId}}", "language", "skip"],
              "variable": [{"key": "userId", "value": ""}]
            },
            "description": "Skips language selection for user"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\"success\": true, \"message\": \"Language selection skipped successfully\", \"data\": {\"userId\": \"60c72b2f9b1d8e001f8e4b5a\", \"preferredLanguage\": null, \"languageSelectionSkipped\": true}}"
            }
          ]
        }
      ]
    },
    {
      "name": "Banners",
      "item": [
        {
          "name": "List Active Banners",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/banners",
              "host": ["{{baseUrl}}"],
              "path": ["banners"]
            },
            "description": "Gets list of active banners for app"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\"success\": true, \"data\": [{\"id\": \"60c72b2f9b1d8e001f8e4b5a\", \"title\": \"Ameerzade ka Badla\", \"subtitle\": \"A STORY TV ORIGINAL\", \"thumbnail\": \"/uploads/thumbnails/banner.png\", \"imageUrl\": \"/uploads/thumbnails/banner.png\", \"ctaText\": \"Watch Now\", \"ctaLink\": null, \"position\": 0, \"isActive\": true, \"content\": {\"id\": \"60c72b2f9b1d8e001f8e4b5b\", \"title\": \"Ameerzade ka Badla\", \"episodeCount\": 10}}], \"pagination\": {\"page\": 1, \"limit\": 20, \"total\": 1, \"pages\": 1}}"
            }
          ]
        },
        {
          "name": "Get Banner Show Details & Episodes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/banners/{{contentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["banners", "{{contentId}}"],
              "variable": [{"key": "contentId", "value": ""}]
            },
            "description": "Gets banner show details and episodes"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\"success\": true, \"data\": {\"content\": {\"id\": \"60c72b2f9b1d8e001f8e4b5b\", \"title\": \"Ameerzade ka Badla\", \"episodeCount\": 10}, \"episodeRanges\": [{\"label\": \"1-10\", \"start\": 1, \"end\": 10}], \"episodes\": [{\"id\": \"60c72b2f9b1d8e001f8e4b5c\", \"episode\": 1, \"title\": \"Ameerzade ka Badla - Episode 1\", \"hlsUrl\": \"/uploads/hls/60c72b2f9b1d8e001f8e4b5b/episode-1/index.m3u8\", \"isFree\": true, \"isLocked\": false, \"processingStatus\": \"ready\"}]}, \"pagination\": {\"page\": 1, \"limit\": 25, \"total\": 10, \"pages\": 1}}"
            }
          ]
        }
      ]
    },
    {
      "name": "Promotions",
      "item": [
        {
          "name": "Get Active Promotion",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/promotions/active",
              "host": ["{{baseUrl}}"],
              "path": ["promotions", "active"]
            },
            "description": "Gets active promotion for app"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\"success\": true, \"data\": {\"id\": \"60c72b2f9b1d8e001f8e4b5d\", \"title\": \"Enjoy Story TV for FREE\", \"subtitle\": \"5 Crore+ people bought the trial offer till now!\", \"features\": [{\"icon\": \"lock\", \"title\": \"Start trial\", \"description\": \"Unlock all dramas\"}]}}"
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "https://ott.kotiboxglobaltech.site/api" },
    { "key": "userId", "value": "" },
    { "key": "contentId", "value": "" }
  ]
}
